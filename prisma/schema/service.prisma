model Service {

  id String @id @default(uuid())

  technician_id String
  category_id String


  title String
  description String?

  price Float
  duration Int
  location String?


  technician TechnicianProfile @relation(fields: [technician_id],references: [id])


  category Category @relation(fields: [category_id],references: [id])


  bookings Booking[]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt


  @@map("services")
}